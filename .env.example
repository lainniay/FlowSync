# Local MySQL container
MYSQL_DATABASE=flowsync
MYSQL_USER=flowsync
MYSQL_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-root-password

# Spring Boot
DB_URL='jdbc:mysql://localhost:3306/flowsync?useUnicode=true&characterEncoding=utf8&connectionTimeZone=Asia%2FShanghai&preserveInstants=true'
DB_USERNAME=flowsync
DB_PASSWORD=change-me

# OpenAI-compatible AI provider (DashScope example)
FLOWSYNC_AI_ENABLED=false
FLOWSYNC_AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
FLOWSYNC_AI_API_KEY=
FLOWSYNC_AI_MODEL=qwen-plus
FLOWSYNC_AI_CONNECT_TIMEOUT=3s
FLOWSYNC_AI_READ_TIMEOUT=30s
FLOWSYNC_AI_RESPONSE_FORMAT=none
FLOWSYNC_AI_MAX_RESPONSE_BYTES=1048576
FLOWSYNC_AI_MAX_CONCURRENT_REQUESTS=5

# Default Admin
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=

# Frontend
VITE_ENABLE_MOCK=true
